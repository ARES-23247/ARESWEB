{
  "entry": [
    "src/main.tsx",
    "functions/api/[[route]].ts",
    "src/pages/**/*.tsx",
    "functions/api/**/*.ts",
    "scripts/**/*.ts"
  ],
  "project": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "shared/**/*.ts",
    "functions/**/*.ts"
  ],
  "ignore": [
