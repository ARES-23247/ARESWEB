rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthorized() {
      return request.auth != null && firestore.exists(/databases/(default)/documents/authorized_users/$(request.auth.uid));
    }

    match /events/{eventId}/photos/{photoId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    match /cad/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    match /telemetry_runs/{allPaths=**} {
      allow read: if isAuthorized();
      allow write: if isAuthorized();
    }

    match /editor/uploads/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    match /field/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    match /fields/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized();
    }
  }
}
