rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get the user's email (normalized to lowercase)
    function getUserEmail() {
      return request.auth != null && request.auth.token != null && request.auth.token.email != null ? request.auth.token.email.lower() : null;
    }
    
    // Helper function to check if the user exists in the authorized_users collection
    function isAuthorized() {
      return isAuthenticated() && exists(/databases/$(database)/documents/authorized_users/$(request.auth.uid));
    }
    
    // Helper function to check if the user has a specific role (e.g. 'admin')
    function hasRole(role) {
      return isAuthorized() && get(/databases/$(database)/documents/authorized_users/$(request.auth.uid)).data.role == role;
    }

    // Rules for the authorized_users collection
    match /authorized_users/{userId} {
      // Users can read their own registration doc; admins can read everything
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
      // Only admins can invite or edit roles, or allow first-time admin bootstrap (if Coach David is missing)
      allow write: if hasRole('admin') || (isAuthenticated() && getUserEmail() == 'coach.david@gmail.com' && !exists(/databases/$(database)/documents/authorized_users/$(request.auth.uid)));
    }

    // Public collections (blogs, calendar, knowledge base docs)
    match /posts/{postSlug} {
      allow read: if true; // Publicly readable
      allow write: if isAuthorized(); // Only team members can create or edit
    }

    match /events/{eventId} {
      allow read: if true; // Publicly readable
      allow write: if isAuthorized(); // Only team members can create or edit

      match /signups/{userId} {
        allow read: if isAuthorized();
        allow write: if isAuthorized() && (request.auth.uid == userId || hasRole('admin'));
      }

      match /photos/{photoId} {
        allow read: if true;
        allow write: if isAuthorized();
      }
    }

    match /docs/{docSlug} {
      allow read: if true; // Publicly readable
      allow write: if isAuthorized(); // Only team members can create or edit
    }

    // Secure team collections (Kanban tasks, AI chat sessions, telemetry runs)
    match /tasks/{taskId} {
      allow read, write: if isAuthorized();
    }

    match /chat_sessions/{sessionId} {
      // Allow read/write for authorized team members, or guests under standard "anonymous" sessions
      allow read: if isAuthorized() || (isAuthenticated() && resource.data.userId == 'anonymous');
      allow create: if isAuthorized() || (isAuthenticated() && request.resource.data.userId == 'anonymous');
      allow update, delete: if isAuthorized() || (isAuthenticated() && resource.data.userId == 'anonymous');
    }

    match /telemetry_runs/{runId} {
      allow read, write: if isAuthorized();
    }

    // Public partners / sponsors
    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // inquiries (securely gated to adminDb server writes only!)
    match /inquiries/{inquiryId} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    // aresplanner_paths
    match /aresplanner_paths/{pathId} {
      allow read, write: if isAuthorized();
    }

    // aresplanner_logs
    match /aresplanner_logs/{logId} {
      allow read, write: if isAuthorized();
    }

    // aresplanner_log_data
    match /aresplanner_log_data/{logId} {
      allow read, write: if isAuthorized();
    }

    // user_profiles
    match /user_profiles/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin') || hasRole('coach') || hasRole('mentor'));
      allow create: if isAuthenticated() && isAuthorized() && (request.auth.uid == userId || hasRole('admin')) &&
                    (!request.resource.data.keys().hasAny(['memberType']) || request.resource.data.memberType == 'student' || hasRole('admin'));
      allow update: if isAuthenticated() && isAuthorized() && (request.auth.uid == userId || hasRole('admin')) &&
                    (!request.resource.data.keys().hasAny(['memberType']) || request.resource.data.memberType == resource.data.memberType || hasRole('admin'));
      allow delete: if hasRole('admin');
    }

    // robots
    match /robots/{robotId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    // settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    // field_configs
    match /field_configs/{configId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    // documents
    match /documents/{docId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    // videos
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAuthorized();
    }
  }
}

