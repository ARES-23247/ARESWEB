rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthorized() {
      return request.auth != null && 
        firestore.exists(/databases/(default)/documents/authorized_users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/authorized_users/$(request.auth.uid)).data.role != 'unverified';
    }

    match /events/{eventId}/photos/{photoId} {
      allow read: if true;
      allow write: if isAuthorized() && request.resource.size < 20 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized() && request.resource.size < 20 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized() && request.resource.size < 20 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /cad/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized() && request.resource.size < 100 * 1024 * 1024;
    }

    match /telemetry_runs/{allPaths=**} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && request.resource.size < 10 * 1024 * 1024;
    }

    match /editor/uploads/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized() && request.resource.size < 20 * 1024 * 1024;
    }

    match /field/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized() && request.resource.size < 50 * 1024 * 1024;
    }

    match /fields/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorized() && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
