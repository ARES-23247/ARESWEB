{
  "defaults": {
    "standard": "WCAG2AA",
    "timeout": 15000,
    "runners": ["axe", "htmlcs"],
    "ignore": ["color-contrast"],
    "chromeLaunchConfig": {
      "args": ["--no-sandbox", "--disable-setuid-sandbox"]
    },
    "hideElements": "#hero-mountaineer-mindset"
  },
  "urls": [
    "http://localhost:4173/",
    "http://localhost:4173/about",
    "http://localhost:4173/dashboard",
    "http://localhost:4173/sponsors",
    "http://localhost:4173/seasons",
    "http://localhost:4173/outreach",
    "http://localhost:4173/tech-stack",
    "http://localhost:4173/accessibility",
    "http://localhost:4173/privacy",
    "http://localhost:4173/join",
    "http://localhost:4173/leaderboard",
    "http://localhost:4173/bug-report",
    "http://localhost:4173/blog",
    "http://localhost:4173/events",
    "http://localhost:4173/docs",
    "http://localhost:4173/judges"
  ]
}
