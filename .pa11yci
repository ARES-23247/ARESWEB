{
  "defaults": {
    "standard": "WCAG2AA",
    "timeout": 15000,
    "runners": ["axe", "htmlcs"],
    "ignore": ["color-contrast"],
    "chromeLaunchConfig": {
      "args": ["--no-sandbox", "--disable-setuid-sandbox"]
    },
    "hideElements": "#hero-mountaineer-mindset"
  },
  "urls": [
    "http://localhost:8788/",
    "http://localhost:8788/about",
    "http://localhost:8788/dashboard",
    "http://localhost:8788/sponsors",
    "http://localhost:8788/seasons",
    "http://localhost:8788/outreach",
    "http://localhost:8788/tech-stack",
    "http://localhost:8788/accessibility",
    "http://localhost:8788/privacy",
    "http://localhost:8788/join",
    "http://localhost:8788/leaderboard",
    "http://localhost:8788/bug-report",
    "http://localhost:8788/blog",
    "http://localhost:8788/events",
    "http://localhost:8788/docs",
    "http://localhost:8788/judges"
  ]
}
